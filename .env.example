# Root Configuration (Hardhat Blockchain Deployment)

# Blockchain Network Configuration
# For local dev: http://127.0.0.1:8545
# For Sepolia: https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your MetaMask Wallet Private Key (Make sure the account has Sepolia ETH)
PRIVATE_KEY=your_metamask_private_key_here

# This will be automatically populated when you run:
# npx hardhat run scripts/deploy.js --network sepolia
CONTRACT_ADDRESS=your_deployed_contract_address_here

# Backend Configuration (Shared)
PORT=5001
FRONTEND_BASE_URL=https://your-frontend-app.vercel.app
ENABLE_IPFS=false
PINATA_JWT=

# Admin Authentication
ADMIN_USERNAME=eternal2026
ADMIN_PASSWORD=god@1244
JWT_SECRET=your_jwt_secret_here
